# ============================================================
# VINCI AI Video Editor — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ✅ REQUIRED — Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_google_ai_studio_key_here

# AI Models (these are the correct working model IDs as of 2025)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# Server
NODE_ENV=development
PORT=3000

# ⬇️ OPTIONAL — Supabase (not currently used by the app, for future auth/storage)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ⬇️ OPTIONAL — Advanced AI features (require local Python setup)
# WAV2LIP_DIR=/app/Wav2Lip
# WAV2LIP_CHECKPOINT=checkpoints/wav2lip_gan.pth
